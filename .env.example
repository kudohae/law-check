# Optional. Leave blank if the public endpoint works without a key.
ASSEMBLY_API_KEY=
LAWMAKING_API_KEY=

# Data sync range. Defaults are free-hosting friendly.
LAW_CHECK_SINCE_DATE=2025-06-01
LAW_CHECK_UNTIL_DATE=
ASSEMBLY_MAX_PAGES=500
ASSEMBLY_PAGE_SIZE=100
LAWMAKING_MAX_PAGES=100
LAWMAKING_CHUNK_DAYS=31
LAW_CHECK_REQUEST_DELAY_MS=1000
LAW_CHECK_RETRY_COUNT=3
LAW_CHECK_RETRY_DELAY_MS=5000

# AI summaries run outside the browser and write results to public/data/bills.json.
SUMMARY_PROVIDER=ollama
SUMMARY_LIMIT=5
SUMMARY_DELAY_MS=1200
SUMMARY_FORCE=0

OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARY_LIMIT=5
GEMINI_SUMMARY_DELAY_MS=1200
