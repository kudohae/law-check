# Optional. Leave blank if the public endpoint works without a key.
ASSEMBLY_API_KEY=
LAWMAKING_API_KEY=

# Data sync range. Defaults are free-hosting friendly.
ASSEMBLY_MAX_PAGES=5
ASSEMBLY_PAGE_SIZE=100
LAWMAKING_MAX_PAGES=5

# AI summaries are intentionally disabled in the zero-cost MVP.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARY_LIMIT=5
GEMINI_SUMMARY_DELAY_MS=1200
