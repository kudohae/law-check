# Optional. Leave blank if the public endpoint works without a key.
ASSEMBLY_API_KEY=
LAWMAKING_API_KEY=

# Data sync range. Defaults are free-hosting friendly.
ASSEMBLY_MAX_PAGES=5
ASSEMBLY_PAGE_SIZE=100
LAWMAKING_MAX_PAGES=5

# AI summaries run outside the browser and write results to public/data/bills.json.
SUMMARY_PROVIDER=ollama
SUMMARY_LIMIT=5
SUMMARY_DELAY_MS=1200
SUMMARY_FORCE=0

OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARY_LIMIT=5
GEMINI_SUMMARY_DELAY_MS=1200

# Seeseon daily issue mindmap generation. Keep keys in .env.local or GitHub Secrets.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

ISSUE_DATE=
ISSUE_CANDIDATE_LIMIT=36
ISSUE_ARCHIVE_LIMIT=30
NAVER_NEWS_DISPLAY=40
ISSUE_RSS_URLS=
